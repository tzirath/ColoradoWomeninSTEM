# Copy this file to .env and fill in your values.
# Never commit the .env file — it contains secrets.

# Google reCAPTCHA v3 — https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Gmail SMTP — use an App Password (not your regular Gmail password)
# https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16char_app_password_here

# Eventbrite API — private token from https://www.eventbrite.com/account-settings/apps
EVENTBRITE_API_KEY=your_eventbrite_private_token_here
